# Public LiveKit signaling URL that browsers use.
# LiveKit listens directly on TCP 7880 in the server deployment.
LIVEKIT_URL=ws://203.0.113.10:7880

# Public IP address of the server. LiveKit advertises this address to browsers for WebRTC media.
LIVEKIT_NODE_IP=203.0.113.10

# Local development credentials. Compose passes the same values to app and LiveKit.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=radiance-dev-secret-change-me-32-chars
