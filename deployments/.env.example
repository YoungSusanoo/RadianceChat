# Default Docker Desktop / WSL profile.
# Copy to deployments/.env and set LAN_HOST to the IP address of the PC that runs Docker.
LAN_HOST=192.168.1.50

# Optional explicit signaling URL. Leave empty to derive ws://host/livekit from the browser request.
LIVEKIT_URL=

# Local development credentials. Keep app and LiveKit values in sync.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
