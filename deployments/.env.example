# Public LiveKit signaling URL that browsers use.
# For the current HTTP server deployment, set this to ws://<server-ip-or-domain>:8080/livekit.
LIVEKIT_URL=ws://203.0.113.10:8080/livekit

# Public IP address of the server. LiveKit advertises this address to browsers for WebRTC media.
LIVEKIT_NODE_IP=203.0.113.10

# Local development credentials. Keep app and LiveKit values in sync.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
